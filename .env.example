# Pixie API — Environment Variables
# Copy this file to .env and fill in your values

# ─── Required ─────────────────────────────────────────────

# MySQL/TiDB connection string
DATABASE_URL=mysql://user:password@host:3306/pixie

# JWT secret for session cookies (generate a random 64-char string)
JWT_SECRET=your-random-jwt-secret-here

# OpenAI API key (or any OpenAI-compatible provider)
OPENAI_API_KEY=sk-your-api-key-here

# ─── Optional (Manus Platform) ───────────────────────────

# Manus built-in API (provides LLM, storage, notifications)
# BUILT_IN_FORGE_API_URL=https://...
# BUILT_IN_FORGE_API_KEY=...

# Manus OAuth (remove if using your own auth)
# VITE_APP_ID=your-app-id
# OAUTH_SERVER_URL=https://api.manus.im
# VITE_OAUTH_PORTAL_URL=https://manus.im/login
# OWNER_OPEN_ID=owner-id
# OWNER_NAME=owner-name

# Alternative LLM provider
# ZHIPU_API_KEY=your-zhipu-key

# ─── Server ──────────────────────────────────────────────

# Server port (default: 3000)
# PORT=3000
